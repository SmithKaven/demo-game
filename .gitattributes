# Unity Specific Binary
*.cubemap filter=lfs diff=lfs merge=lfs -text
*.unitypackage filter=lfs diff=lfs merge=lfs -text

# Collapse Unity YAML
*.unity -text merge=unityyamlmerge diff
*.prefab -text merge=unityyamlmerge diff
*.asset -text merge=unityyamlmerge diff

# Force LF for scripts and shaders
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.lua text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.md text eol=lf
